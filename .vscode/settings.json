{
    // "terminal.integrated.cwd": "Drive/04. Competition (due Jun 12th 11AM UTC)/competition/attempt/",
    "files.exclude": {
       // "**/*.venv": true,
        // "**/*.ipynb": true,
        "**/template": true,
        "**/__pycache__": true,
        "**/__init__.py": true,
        // TEMPLATE
        "**/Template/**": true,
        "**/template/**": true,
        "**/TEMPLATE/**": true,
        "**/templates/**": true,
        "**/TEMPLATES/**": true,
        "**/TEMPLATE_FILES/**": true,
        "**/template_files/**": true,
        "**/template-files/**": true,
        "**/TEMPLATE-FILES/**": true,
        // LATEX
        "**/.git": true,
        "**/*.snm": true,
        "**/.toc": true,
        "**/*.aux": true,
        "**/*.blg": true,
        "**/*.bbl": true,
        "**/*.idx": true,
        "**/*.ind": true,
        "**/*.ilg": true,
        "**/*.lof": true,
        "**/*.lot": true,
        "**/*.out": true,
        "**/*.nav": true,
        "**/*.log": true,
        "**/*.glo": true,
        "**/*.ist": true,
        "**/*.acn": true,
        "**/*.toc": true,
        "**/*.bcf": true,
        "**/*.xml": true,
        "**/*.synctex(busy)": true,
        "**/*.bbl-SAVE-ERROR": true,
        "**/*.bcf-SAVE-ERROR": true,
        "**/*.synctex.gz": true,
        "**/*.fdb_latexmk": true,
        "**/*.fls": true,
        // OTHERS
        // "**/Template/**": true,
        "**/**.lock": true,
        "**/**/__pycache__/**": true
        // ".venv/**": true,
        //    "**/**.ipynb": true
    },
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "jupyter.interactiveWindow.creationMode": "perFile"
}